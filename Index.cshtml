@page
@model IndexModel
@{
   

    ViewData["Title"] = "Home page";
     <link rel="stylesheet" href="~/css/css.css" />

}

<div class="text-center">
    

    <h1 class="display-1">Ragnarock præsenterer: Gasolin'</h1>
    <p>Gasolins' historie</p>

    <div class="d-inline-flex">
        <a asp-page="/NySide/KimLarsen">Kort om Kim Larsen</a>
        <a asp-page="/NySide/FranzBeckerLee">Kort om Franz Becker Lee</a>
        <a asp-page="/NySide/WiliJønsson">Kort om Wili Jønsson</a>
        <a asp-page="/NySide/BjørnUglebjerg">Kort om Bjørn Uglebjerg</a>
    </div>
    <h2>Her får du en tidslinje af bandet:</h2>
@functions {
    public class TimelineEvent
    {
        public int Year { get; set; }
        public string Event { get; set; }
    }
}

@{
    var timeline = new List<TimelineEvent>
    {
        new TimelineEvent { Year = 1969, Event = "Bandet dannes" },
        new TimelineEvent { Year = 1971, Event = "Første album" },
        new TimelineEvent { Year = 1978, Event = "Opløsning" }
    };
}

@foreach (var item in timeline)
{
    <div>
        <h2>@item.Year</h2>
        <p>@item.Event</p>
    </div>
}
   <h3>
        Gasolin' var en dansk rockgruppe, der blev dannet i 1969 på Christianshavn og eksisterede omkring ni år frem. 
        Gruppen bestod af Wili Jønsson, Franz Beckerlee, Bjørn Uglebjerg – senere erstattet af Søren Berlev – 
        og med Kim Larsen som forsanger og frontfigur. 
        Det var især forholdet mellem guitaristen Franz Beckerlee og sangeren Kim Larsen, der slog gnister. 
        Konflikten mellem de to var hovedårsagen til Gasolins opløsning.
    </h3>
</div>

